# OpenAI API Configuration
OPENAI_API_KEY=sk_your_key_here

# Google Drive API Configuration
GOOGLE_DRIVE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=your_client_secret
GOOGLE_DRIVE_REFRESH_TOKEN=your_refresh_token
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_for_stories

# YouTube API Configuration
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_ID=your_channel_id

# Application Configuration
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Video Format Configuration (9:16 Vertical)
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_ASPECT_RATIO=9:16
VIDEO_RESOLUTION=1080x1920
VIDEO_FRAME_RATE=30
VIDEO_BITRATE=3000k
VIDEO_FORMAT=vertical
VIDEO_CODEC=libx264
AUDIO_CODEC=aac
VIDEO_DURATION=180

# Story Generation Settings
DAILY_EPISODES_COUNT=10
EPISODE_WORD_COUNT_MIN=400
EPISODE_WORD_COUNT_MAX=600
EPISODE_DURATION_MINUTES=3

# Scheduler Settings
ENABLE_AUTO_GENERATION=true
GENERATION_TIME=00:00
VIDEO_GENERATION_ENABLED=true
YOUTUBE_UPLOAD_ENABLED=true

# Narration Settings
NARRATION_ENGINE=browser-speech
NARRATION_VOICE_LANG=en-US
NARRATION_VOICE_RATE=1.0

# Video Animation Settings
ENABLE_TEXT_ANIMATION=true
ENABLE_PARALLAX_BACKGROUND=true
TEXT_ANIMATION_SPEED=medium
BACKGROUND_STYLE=dark-gradient

# YouTube Shorts Publishing Settings
YOUTUBE_PUBLISH_TIME_START=06:00
YOUTUBE_PUBLISH_TIME_INTERVAL=120
PUBLISH_SCHEDULE_ENABLED=true
YOUTUBE_SHORTS_FORMAT=true

# Database Settings
DB_TYPE=json
STORIES_DB_PATH=./data/stories.json
CHARACTERS_DB_PATH=./data/characters.json
LOCATIONS_DB_PATH=./data/locations.json
STORYLINES_DB_PATH=./data/storylines.json

# Story Categories (comma-separated)
STORY_CATEGORIES=Fantasy,Romance,Loyalty,ArmySoldiers,EliteRangers,VillageMysterics,Spirits,Witches,AncientPowers,YouthHeroes,LostCivilizations,PNG-inspiredLegends,Adventure,SupernaturalThriller

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
